  <section id="reservations" class="bg-cream">
    <div class="max-w-screen-xl mx-auto px-6 py-20">

      <div class="text-center mb-12">
        <p class="font-body font-bold text-xs uppercase tracking-widest text-amber mb-3">Join Us</p>
        <h2 class="font-heading text-4xl md:text-5xl text-espresso mb-4">Reservations</h2>
        <div class="flex items-center justify-center gap-3">
          <span class="block w-12 h-px bg-amber/50"></span>
          <span class="text-amber">&#9670;</span>
          <span class="block w-12 h-px bg-amber/50"></span>
        </div>
      </div>

      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

        {# Image with rounded corners floating over background #}
        <div class="flex-1 w-full fade-up">
          <img src="{{ '/assets/images/interior-3.jpg' | url }}" alt="Nadine's dining room" class="w-full h-[480px] object-cover rounded-2xl shadow-xl">
        </div>

        {# Widget + blurb #}
        <div class="flex-none w-full lg:w-[320px] flex flex-col items-start fade-up" style="transition-delay: 0.15s">
          <p class="font-body text-espresso/70 text-lg leading-relaxed mb-8">
            We'd love to have you. Book your table below and we'll have everything ready for your visit.
          </p>
          <iframe id="widget" width="300" height="442" src="https://88restaurants.com/799/widgets/302" style="border: none; background: none; border-radius: 5px;"></iframe>
        </div>

      </div>
    </div>
