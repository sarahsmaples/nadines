---
title: "Nadine's Restaurant | German, Austrian & French Cuisine | Yorktown Heights, NY"
description: "Nadine's Restaurant in Yorktown Heights, NY serves traditional German, Austrian, and French dishes in a warm, welcoming atmosphere. Dine in, order online, or book a reservation."
---

{% extends "layouts/base.njk" %}

{% block head %}
<script id="marketing-popup-script" data-restaurant-id="799" src="https://88restaurants.com/uploads/popup.js"></script>
{% endblock %}

{% block scripts %}
<script>
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const response = await fetch(
        "https://88restaurants.com/restaurants/799/online_orders/discount_button"
      );
      const html = await response.text();
      document.body.insertAdjacentHTML("beforeend", html);
    } catch (error) {
      console.error("Error fetching button:", error);
    }
  });
</script>
{% endblock %}

{% block content %}
  {# ── HERO ── #}
  <section class="bg-cream overflow-hidden relative">
    {# Fraktur watermark #}
    <span class="font-fraktur text-[8rem] md:text-[16rem] leading-none text-amber/10 select-none pointer-events-none absolute inset-0 flex items-center justify-center whitespace-nowrap overflow-hidden">Gemütlichkeit</span>
    <div class="max-w-screen-xl mx-auto px-6 pt-16 pb-16 md:pt-24 md:pb-24 flex flex-col md:flex-row md:items-center gap-12 md:gap-16 relative z-10">

      {# Left: text #}
      <div class="flex-1 max-w-xl fade-up">
        <p class="font-body font-bold text-xs uppercase tracking-widest text-amber mb-3">Yorktown Heights, NY</p>
        <div class="flex gap-1.5 mb-6">
          <span class="text-amber text-lg">&#9670;</span>
          <span class="text-amber text-lg">&#9670;</span>
          <span class="text-amber text-lg">&#9670;</span>
        </div>
        <h1 class="font-heading text-5xl md:text-6xl leading-tight text-espresso mb-6">
          Traditional Flavors,<br>Warmly <em class="not-italic text-amber">Shared</em>
        </h1>
        <p class="font-body text-espresso/70 text-lg leading-relaxed mb-10">
          German, Austrian & French cuisine in the heart of Yorktown — crafted with care, served with <em>gemütlichkeit</em>.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="{{ '/menu/' | url }}" class="btn-primary">View Menu</a>
          <a href="#reservations" class="btn-outline">Book a Table</a>
        </div>
      </div>

      {# Right: image carousel #}
      <div class="flex-1 flex items-center justify-center fade-up" style="transition-delay: 0.15s">
        <div class="relative w-72 h-72 md:w-96 md:h-96">
          {# Decorative rings #}
          <div class="absolute inset-0 rounded-full border-2 border-amber/40 scale-110"></div>
          <div class="absolute inset-0 rounded-full border border-amber/20 scale-125"></div>
          {# Images — add/remove <img> tags here as needed #}
          <div id="hero-slides" class="w-full h-full">
            <img src="{{ '/assets/images/hero-1.png' | url }}" alt="Nadine's Restaurant" class="hero-slide w-full h-full object-contain absolute inset-0 transition-opacity duration-1000 opacity-100">
            <img src="{{ '/assets/images/hero-2.png' | url }}" alt="Nadine's Restaurant" class="hero-slide w-full h-full object-contain absolute inset-0 transition-opacity duration-1000 opacity-0">
            <img src="{{ '/assets/images/hero-3.png' | url }}" alt="Nadine's Restaurant" class="hero-slide w-full h-full object-contain absolute inset-0 transition-opacity duration-1000 opacity-0">
          </div>
        </div>
      </div>

    </div>
  </section>

  <section id="about" class="bg-cream overflow-hidden">


    <div class="max-w-screen-xl mx-auto px-6 pb-20 flex flex-col lg:flex-row gap-12 lg:gap-16 items-center">

      {# Mosaic #}
      <div class="flex-1 grid grid-cols-3 gap-3 h-[480px] lg:h-[560px] fade-up">
        {# plates-1: tall skinny far left, spans full height #}
        <div class="row-span-2 rounded-2xl overflow-hidden col-span-1">
          <img src="{{ '/assets/images/plates-1.jpg' | url }}" alt="Nadine's dishes" class="w-full h-full object-cover">
        </div>
        {# interior and exterior stacked on the right two columns #}
        <div class="rounded-2xl overflow-hidden col-span-2">
          <img src="{{ '/assets/images/interior-1.jpg' | url }}" alt="Nadine's interior" class="w-full h-full object-cover">
        </div>
        <div class="rounded-2xl overflow-hidden col-span-2">
          <img src="{{ '/assets/images/exterior-1.jpg' | url }}" alt="Nadine's exterior" class="w-full h-full object-cover">
        </div>
      </div>

      {# Text #}
      <div class="flex-1 max-w-xl fade-up" style="transition-delay: 0.15s">
        <p class="font-body font-bold text-xs uppercase tracking-widest text-amber mb-3">Our Story</p>
        <h2 class="font-heading text-4xl md:text-5xl text-espresso mb-6">Welcome to<br>Nadine's</h2>
        <p class="font-body text-espresso/70 text-lg leading-relaxed mb-5">
          Christian and Pamela Schienle, along with their son Jagger, have opened Nadine's Restaurant — formerly Jennifer's German Restaurant in Yorktown for over thirty years. The Schienle family have been searching for the perfect location for a sister restaurant to Sel et Poivre in NYC, a French bistro that has been in the family for three decades.
        </p>
        <p class="font-body text-espresso/70 text-lg leading-relaxed mb-5">
          With Christian being from Vienna, Austria, they crafted a menu combining traditional German dishes with French classics — plus a special dish of the night.
        </p>
        <p class="font-body text-espresso/70 text-lg leading-relaxed">
          Nadine is Pamela's middle name, and represents their passion for food, hospitality, family and friends — or, as they say in Austria, <span class="font-fraktur text-2xl text-espresso">Gemütlichkeit</span>.
        </p>
      </div>

    </div>
  </section>

  {# ── MENUS ── #}
  <section class="relative bg-espresso overflow-hidden">
    {# Background image with dark overlay #}
